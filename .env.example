# ============================================================
# Umbral Agent Stack  Environment Variables (plantilla)
# ============================================================
# 1) Copiar a .env:    copy .env.example .env
# 2) Rellenar .env con valores reales. NUNCA commitear .env
# 3) Opcional: ejecutar scripts/set_env_from_dotenv.ps1 para pasar .env a variables de entorno de Windows
# ============================================================

# --- Worker HTTP ---
WORKER_URL=http://127.0.0.1:8088
WORKER_URL_VM=http://<VM_TAILSCALE_IP>:8088
WORKER_URL_VM_GUI=http://<VM_TAILSCALE_IP>:8089
WORKER_URL_VM_INTERACTIVE=http://<VM_TAILSCALE_IP>:8089
WORKER_TOKEN=CHANGE_ME_WORKER_TOKEN

# --- Notion: Rick (core) ---
NOTION_API_KEY=CHANGE_ME_NOTION_API_KEY
NOTION_CONTROL_ROOM_PAGE_ID=CHANGE_ME_CONTROL_ROOM_PAGE_ID
NOTION_DASHBOARD_PAGE_ID=CHANGE_ME_DASHBOARD_PAGE_ID

# --- Notion: Supervisor (opcional; alertas con identidad propia en Dashboard) ---
# NOTION_SUPERVISOR_API_KEY=CHANGE_ME_SUPERVISOR_INTEGRATION_TOKEN
# NOTION_SUPERVISOR_ALERT_PAGE_ID=CHANGE_ME_DASHBOARD_PAGE_ID

# --- Notion: opcionales por funcionalidad ---
NOTION_TASKS_DB_ID=CHANGE_ME_NOTION_TASKS_DB_ID
NOTION_BITACORA_DB_ID=CHANGE_ME_NOTION_BITACORA_DB_ID   # required for bitacora scripts (add_resumen_amigable, enrich_bitacora_pages)
NOTION_PROJECTS_DB_ID=CHANGE_ME_NOTION_PROJECTS_DB_ID   # project registry DB used by notion.upsert_project
# NOTION_GRANOLA_DB_ID=CHANGE_ME_NOTION_GRANOLA_DB_ID   # solo si usas pipeline Granola; usa NOTION_API_KEY (Rick)

# --- GitHub (Rick: PR, push desde VPS + GitHub Models para LLM fallback) ---
# GITHUB_TOKEN también habilita GitHub Models API como fallback para GPT y Claude.
GITHUB_TOKEN=CHANGE_ME_GITHUB_TOKEN

# --- Azure AI Foundry (prioridad máxima para modelos OpenAI/Codex) ---
# Proveedor de mayor prioridad para gpt-5.3-codex y modelos OpenAI con cuota dedicada Azure.
# Endpoint: https://mi-recurso.openai.azure.com/  (Azure OpenAI clásico)
#           https://mi-hub.services.ai.azure.com/ (AI Foundry Hub, nuevo)
AZURE_OPENAI_ENDPOINT=CHANGE_ME_AZURE_OPENAI_ENDPOINT
AZURE_OPENAI_API_KEY=CHANGE_ME_AZURE_OPENAI_API_KEY
AZURE_OPENAI_DEPLOYMENT=gpt-5.3-codex   # nombre del deployment en Foundry
# AZURE_OPENAI_API_VERSION=2024-12-01-preview  # opcional, ya tiene default

# --- Agente Gpt-Rick (Azure AI Foundry Cursor) ---
# Rick puede asignar tareas al agente publicado. Usa AZURE_OPENAI_API_KEY o GPT_RICK_API_KEY.
# Test: python3 scripts/test_gpt_rick_agent.py
# GPT_RICK_API_KEY=CHANGE_ME_GPT_RICK_API_KEY   # opcional; fallback: AZURE_OPENAI_API_KEY

# --- gpt-realtime (audio TTS, cursor-api-david.cognitiveservices.azure.com) ---
# Test audio: python3 scripts/test_gpt_realtime_audio.py → guarda assets/audio/rick_audio_prueba.wav

# --- Anthropic (Claude Sonnet/Opus via API nativa) ---
ANTHROPIC_API_KEY=CHANGE_ME_ANTHROPIC_API_KEY

# --- OpenClaw Gateway (Claude via proxy local en VPS, puerto 18789) ---
# El Worker puede llamar a Claude a través de OpenClaw corriendo en la misma VPS.
# Si OPENCLAW_GATEWAY_TOKEN está configurado, los modelos claude-* se rutean automáticamente.
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_OPENCLAW_GATEWAY_TOKEN
# Opcional: override de URL (default: http://localhost:18789)
# OPENCLAW_GATEWAY_URL=http://localhost:18789

# --- OpenAI directo (opcional, fallback si no hay Foundry ni GitHub Models) ---
# OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY

# --- Langfuse (LLM tracing) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Google Cloud / Custom Search / Gemini (Rick: SIM, doc 35) ---

# --- Google Gemini (AI Studio) — Search Grounding + LLM ---
# Proyecto: My First Project (300115066900) — billing activo
# Key: Rick Nano Banana — restringida a generativelanguage.googleapis.com
# Soporta: gemini-2.5-flash con tools=[google_search] (web grounding CONFIRMADO)
GOOGLE_API_KEY=CHANGE_ME_GOOGLE_API_KEY

# --- Google Cloud APIs (NL, BigQuery, Vertex AI, Storage) ---
# Key: rick-umbral-apis-3 — restringida a language + bigquery + storage + aiplatform + customsearch
# Usos confirmados: Cloud Natural Language API, BigQuery, Vertex AI, Storage
GOOGLE_CLOUD_API_KEY=CHANGE_ME_GOOGLE_CLOUD_API_KEY

GOOGLE_API_KEY_NANO=CHANGE_ME_GOOGLE_API_KEY_NANO
GOOGLE_CSE_API_KEY_RICK_UMBRAL=CHANGE_ME_GOOGLE_CSE_API_KEY
GOOGLE_CLOUD_PROJECT_RICK_UMBRAL=CHANGE_ME_GOOGLE_CLOUD_PROJECT_ID
GOOGLE_CSE_CX=CHANGE_ME_GOOGLE_CSE_CX

# --- Búsqueda web alternativa (Rick: SIM discovery si Custom Search 403; doc 36) ---
# Azure Bing no disponible para cuentas nuevas (Microsoft depreco). Fallback: Tavily.
TAVILY_API_KEY=CHANGE_ME_TAVILY_API_KEY

# --- Hostinger (Rick: monitoreo, proyectos web) ---
HOSTINGER_API_TOKEN=CHANGE_ME_HOSTINGER_API_TOKEN

# --- Linear ---
LINEAR_API_KEY=CHANGE_ME_LINEAR_API_KEY
LINEAR_WEBHOOK_SECRET=CHANGE_ME_LINEAR_WEBHOOK_SECRET   # required for webhook HMAC validation

# --- Telegram (para scripts/send_telegram_to_rick.py: enviar mensaje al chat con Rick) ---
# TELEGRAM_BOT_TOKEN=CHANGE_ME_TELEGRAM_BOT_TOKEN
# TELEGRAM_CHAT_ID=1813248373

# --- Make.com (Rick: análisis de mercado / SIM; doc 39) ---
# MAKE_API_TOKEN=CHANGE_ME_MAKE_API_TOKEN
# MAKE_WEBHOOK_SIM_RUN=https://hook.eu1.make.com/xxxx

# --- n8n (Rick: workflows desde VPS; doc 37, 39) ---
# N8N_URL=http://127.0.0.1:5678
# N8N_API_KEY=CHANGE_ME_N8N_API_KEY

# --- Figma API (Rick: leer archivos, exportar frames, agregar comentarios) ---
# Obtener en: figma.com → Settings → Security → Personal access tokens
FIGMA_API_KEY=CHANGE_ME_FIGMA_PERSONAL_ACCESS_TOKEN

# --- Google Calendar / Gmail (OAuth Bearer o Service Account) ---
GOOGLE_CALENDAR_TOKEN=CHANGE_ME_GOOGLE_CALENDAR_OAUTH_TOKEN
GOOGLE_GMAIL_TOKEN=CHANGE_ME_GOOGLE_GMAIL_OAUTH_TOKEN
# Opción que no expira: refresh token + client id/secret (ver docs/35-gmail-token-setup.md)
# GOOGLE_GMAIL_REFRESH_TOKEN=1//0...
# GOOGLE_GMAIL_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_GMAIL_CLIENT_SECRET=GOCSPX-...
# Alternativa: ruta a JSON de Service Account con scopes calendar + gmail
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# --- Granola Pipeline (VM watcher → Worker → Notion; doc 50) ---
GRANOLA_EXPORT_DIR=C:\Users\rick\Documents\Granola
GRANOLA_PROCESSED_DIR=C:\Users\rick\Documents\Granola\processed
# ENLACE_NOTION_USER_ID=CHANGE_ME_ENLACE_USER_ID  # Para @mentions en Notion

# --- Granola Watcher (VM Windows — en C:\Granola\.env, no en VPS) ---
# Estas variables van en C:\Granola\.env en la VM (el instalador las configura).
# GRANOLA_EXPORT_DIR=C:\Granola\exports
# GRANOLA_WORKER_URL=http://localhost:8088
# GRANOLA_WORKER_TOKEN=CHANGE_ME_SAME_AS_WORKER_TOKEN
# GRANOLA_NOTION_DATABASE_ID=CHANGE_ME_NOTION_DATABASE_ID
# GRANOLA_POLL_INTERVAL=5

# --- Tailscale IPs (referencia) ---
# VPS_TAILSCALE_IP=<VPS_TAILSCALE_IP>
# VM_TAILSCALE_IP=<VM_TAILSCALE_IP>
