# ============================================================
# Umbral Agent Stack — Environment Variables
# ============================================================
# Copiar a .env y rellenar con valores reales.
# NUNCA commitear .env con valores reales.
# ============================================================

# --- Worker HTTP ---
WORKER_TOKEN=CHANGE_ME_WORKER_TOKEN
WORKER_PORT=8088

# --- Worker Client (VPS side) ---
WORKER_URL=http://CHANGE_ME_WINDOWS_TAILSCALE_IP:8088

# --- Notion API ---
NOTION_API_KEY=CHANGE_ME_NOTION_API_KEY
NOTION_CONTROL_ROOM_PAGE_ID=CHANGE_ME_CONTROL_ROOM_PAGE_ID
NOTION_GRANOLA_DB_ID=CHANGE_ME_GRANOLA_DB_ID

# --- Tailscale IPs (reference, not used by code) ---
# VPS_TAILSCALE_IP=100.113.249.25
# WINDOWS_TAILSCALE_IP=100.109.16.40
