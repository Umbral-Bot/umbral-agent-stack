# ==============================
# Umbral Agent Stack - .gitignore
# ==============================

# === SECRETS & CREDENTIALS ===
.env
*.env
!env.template
openclaw/env
**/auth-profiles.json
**/sessions/
**/*.bak

# === OpenClaw state ===
.openclaw/
/.openclaw/

# === Logs ===
*.log
logs/
service_out.txt
test_out.txt

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
env/
.pytest_cache/
*.egg-info/
dist/
build/
*.egg

# === Node / npm ===
node_modules/
npm-debug.log*

# === IDE ===
.vscode/
.idea/
*.swp
*.swo
*~

# === OS ===
Thumbs.db
.DS_Store
desktop.ini

# === Docker ===
docker-compose.override.yml

# === Misc ===
*.tmp
*.bak
*.orig
