        LG["LangGraph<br/>(orquestador)"]
        LL["LiteLLM Proxy<br/>:4000"]
        RD["Redis<br/>:6379"]
    end

    subgraph "Fase 3 (TODO)"
        LF["Langfuse<br/>:3000"]
        PG["PostgreSQL"]
        CH["ChromaDB<br/>:8000"]
        PAD["PAD"]
    end

