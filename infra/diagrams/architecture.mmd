%% Umbral Agent Stack — Architecture Diagram
%% Fuente canónica para el diagrama de arquitectura.
%% Renderizar con: https://mermaid.live/ o integración Mermaid en Markdown.

graph LR
    subgraph Internet
        User["👤 Usuario"]
        TG["📱 Telegram API"]
        LLM_API["🧠 OpenAI API"]
    end

    subgraph VPS["🖥️ VPS Hostinger (Ubuntu 24)"]
        OC["OpenClaw Gateway<br/>systemd 24/7"]
        OC_UI["Control UI<br/>:18789 (loopback)"]
    end

    subgraph Tailscale["🔒 Tailscale Mesh"]
        TS_VPS["VPS Node"]
        TS_WIN["Windows Node"]
    end

    subgraph Windows["💻 Windows 11"]
        Worker["⚙️ Worker FastAPI<br/>:8088 (NSSM)"]
    end

    User -->|mensaje| TG
    TG -->|webhook/poll| OC
    OC -->|API call| LLM_API
    OC --> OC_UI
    OC -->|HTTP POST /run| TS_VPS
    TS_VPS ---|WireGuard| TS_WIN
    TS_WIN --> Worker
    Worker -->|response| TS_WIN

    %% === FASE 2/3 — TODO ===
