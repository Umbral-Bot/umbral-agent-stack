# EXAMPLE — non-secret runtime flags for the Copilot CLI capability.
# Target install path (NOT created by F6 step 2):
#   /etc/umbral/copilot-cli.env
# Required permissions when installed:
#   owner rick:rick, mode 0600
#
# This file declares operator flags ONLY. NEVER add COPILOT_GITHUB_TOKEN
# here — secrets live in /etc/umbral/copilot-cli-secrets.env so rotation
# is decoupled from runtime configuration.
#
# All four conditions must be true for real execution:
#   1) RICK_COPILOT_CLI_ENABLED=true   (this file)
#   2) config/tool_policy.yaml :: copilot_cli.enabled: true (repo)
#   3) RICK_COPILOT_CLI_EXECUTE=true   (this file)
#   4) _REAL_EXECUTION_IMPLEMENTED=True (worker/tasks/copilot_cli.py — code)
RICK_COPILOT_CLI_ENABLED=false
RICK_COPILOT_CLI_EXECUTE=false

# Optional: pin the sandbox image tag (deterministic build).
# COPILOT_CLI_SANDBOX_IMAGE=umbral-sandbox-copilot-cli:6940cf0f274d
