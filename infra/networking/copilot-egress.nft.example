# NOTE: THIS FILE IS A REPO TEMPLATE — DO NOT APPLY WITHOUT A LIVE RUNBOOK.
#
# Scoped egress profile for the Copilot CLI sandbox. This template is designed
# for a dedicated Docker bridge network named `copilot-egress` whose Linux
# bridge interface is `br-copilot`.
#
# Required Docker network shape (operator-created during a run window only):
#
#   docker network create \
#     --driver bridge \
#     --opt com.docker.network.bridge.name=br-copilot \
#     --opt com.docker.network.bridge.enable_icc=false \
#     copilot-egress
#
# IMPORTANT SAFETY PROPERTY:
#   This nft table MUST NOT hook host `output` with `policy drop`.
#   F8A evidence on 2026-05-06 showed the former host-wide output policy
#   blocked Notion API calls from the worker. The current table hooks only
#   `forward`, keeps `policy accept`, and drops only packets whose ingress
#   interface is `br-copilot`.
#
# Parse-check only:
#   sudo nft -c -f infra/networking/copilot-egress.nft.example
#
# Apply procedure (operator only, inside an approved run window):
#   1. Create/verify Docker network `copilot-egress` -> bridge `br-copilot`.
#   2. Resolve allowed endpoint IPs with scripts/copilot_egress_resolver.py.
#   3. sudo nft -f infra/networking/copilot-egress.nft.example
#   4. Populate copilot_v4 / copilot_v6 sets from resolver output.
#   5. Run the sandbox with --network=copilot-egress.
#
# Rollback:
#   sudo nft delete table inet copilot_egress
#   docker network rm copilot-egress   # only if no container is using it

define copilot_bridge = "br-copilot"

table inet copilot_egress {

    # IP sets are filled by the resolver script before a run window.
    set copilot_v4 {
        type ipv4_addr
        flags interval
    }

    set copilot_v6 {
        type ipv6_addr
        flags interval
    }

    chain forward {
        type filter hook forward priority filter; policy accept;

        # Never affect host-originated traffic or unrelated Docker bridges.
        iifname != $copilot_bridge accept

        # Allow return traffic for connections initiated by the sandbox.
        ct state established,related accept

        # DNS from the sandbox. The allow-list still gates TCP/443 below.
        udp dport 53 accept
        tcp dport 53 accept

        # Copilot CLI HTTPS endpoints — IPv4
        tcp dport 443 ip daddr @copilot_v4 \
            log prefix "copilot-egress accept v4: " level info \
            accept

        # Copilot CLI HTTPS endpoints — IPv6
        tcp dport 443 ip6 daddr @copilot_v6 \
            log prefix "copilot-egress accept v6: " level info \
            accept

        # Scoped default deny: only packets from br-copilot reach here.
        log prefix "copilot-egress DROP scoped: " level warn flags all
        counter drop
    }
}

# Endpoints that MUST resolve into copilot_v4 / copilot_v6 (mirror of
# config/tool_policy.yaml :: copilot_cli.egress.allowed_endpoints).
# These comments are read by scripts/verify_copilot_egress_contract.py
# to assert design / policy parity.
#
#   allowed: api.githubcopilot.com
#   allowed: api.individual.githubcopilot.com
#   allowed: api.business.githubcopilot.com
#   allowed: api.enterprise.githubcopilot.com
#   allowed: api.github.com
#   allowed: copilot-proxy.githubusercontent.com
