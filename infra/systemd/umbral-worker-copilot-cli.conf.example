# systemd drop-in EXAMPLE for the Copilot CLI capability.
#
# This file is a REPO ARTIFACT. It is NOT installed by F6 step 2.
# Installation will happen in a future F6 step under explicit human review.
#
# Target install path (when authorized):
#   /etc/systemd/system/umbral-worker.service.d/copilot-cli.conf
#
# Then:
#   sudo systemctl daemon-reload
#   sudo systemctl restart umbral-worker
#
# Required env files (also NOT created by step 2 — see infra/env/*.example):
#   /etc/umbral/copilot-cli.env          # owner rick:rick, mode 0600, no secrets
#   /etc/umbral/copilot-cli-secrets.env  # owner rick:rick, mode 0600, secrets only
#
# The leading "-" on EnvironmentFile makes systemd tolerate absence (the
# capability stays disabled by default at the worker layer in that case).
# Once the files are provisioned, the leading "-" can stay — defense in
# depth against accidental removal triggering a hard worker failure.
#
# This drop-in does NOT enable the capability. The capability requires:
#   1) RICK_COPILOT_CLI_ENABLED=true   (in copilot-cli.env)
#   2) config/tool_policy.yaml :: copilot_cli.enabled: true (in repo)
#   3) RICK_COPILOT_CLI_EXECUTE=true   (in copilot-cli.env)
#   4) _REAL_EXECUTION_IMPLEMENTED=True (worker/tasks/copilot_cli.py — code)
#
# See: docs/copilot-cli-capability-design.md
#      docs/copilot-cli-f6-step1-token-plumbing-evidence.md
#      docs/copilot-cli-f6-step2-envfile-artifacts-evidence.md

[Service]
EnvironmentFile=-/etc/umbral/copilot-cli.env
EnvironmentFile=-/etc/umbral/copilot-cli-secrets.env
