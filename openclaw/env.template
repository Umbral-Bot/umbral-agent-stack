# ============================================================
# OpenClaw Environment Template
# ============================================================
# Copiar a ~/.config/openclaw/env y rellenar con valores reales.
# NUNCA commitear este archivo con valores reales.
# chmod 600 ~/.config/openclaw/env
# ============================================================

# --- Worker: VPS autosuficiente (local) + VM opcional (doc 21) ---
WORKER_URL=http://127.0.0.1:8088
WORKER_TOKEN=CHANGE_ME_WORKER_TOKEN
# Opcional: si definís WORKER_URL_VM, improvement/lab van a la VM cuando esté online
# WORKER_URL_VM=http://IP_TAILSCALE_VM:8088

# --- Notion (Control Room, Dashboard; doc 18, 22) ---
# NOTION_API_KEY=...
# NOTION_CONTROL_ROOM_PAGE_ID=...   # Pagina donde Rick/Enlace comentan; poller lee a las XX:10
# NOTION_DASHBOARD_PAGE_ID=...      # Pagina Dashboard Rick (actualizada por dashboard_report_vps.py)
# NOTION_TASKS_DB_ID=xxx            # Opcional, doc 27
# NOTION_PROJECTS_DB_ID=xxx         # Registro maestro de proyectos (notion.upsert_project)
# NOTION_DELIVERABLES_DB_ID=xxx     # Entregables Rick - Revision (notion.upsert_deliverable)

# --- Gateway ---
# OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_GATEWAY_TOKEN

# --- LLM Providers (si se necesitan como env vars) ---
# OPENAI_API_KEY=CHANGE_ME_OPENAI_KEY
# ANTHROPIC_API_KEY=CHANGE_ME_ANTHROPIC_KEY

# --- Telegram (si se configura por env) ---
# TELEGRAM_BOT_TOKEN=CHANGE_ME_TELEGRAM_BOT_TOKEN
# TELEGRAM_CHAT_ID=1813248373   # Opcional; para scripts/send_telegram_to_rick.py (chat donde David habla con Rick)

# --- Google Cloud (Rick: SIM, análisis de mercado; doc 35) ---
# GOOGLE_CSE_API_KEY_RICK_UMBRAL=...   # API key restringida a Natural Language, Vertex, BigQuery, Storage, Custom Search. Límite 255 USD.
# GOOGLE_CLOUD_PROJECT_ID=...         # Opcional: ID del proyecto GCP

# --- Búsqueda web alternativa (Rick: SIM discovery si Custom Search da 403; doc 36) ---
# Azure Bing no disponible para cuentas nuevas. Fallback: Tavily (1000 creditos/mes free).
# TAVILY_API_KEY=...   # app.tavily.com o docs.tavily.com

# --- Make.com (Rick: orquestar escenarios para análisis de mercado / SIM; doc 39) ---
# Opción A: API token (Profile → API en Make) para ejecutar escenarios por API.
# MAKE_API_TOKEN=...
# Opción B: URLs de webhook por escenario (sin token).
# MAKE_WEBHOOK_SIM_RUN=https://hook.eu1.make.com/xxxx
# MAKE_WEBHOOK_SIM_URL=https://hook.make.com/...   # Webhook para pipeline SIM→Make (scripts/sim_to_make.py)

# --- n8n (Rick: disparar workflows desde VPS; doc 37, 39) ---
# N8N_URL=http://127.0.0.1:5678
# N8N_API_KEY=...   # Opcional; o usar solo webhooks del workflow
