{
  "_doc": "Per-fixture rules for evaluator. Multi-format extension: `formats` block defines per-format rule overrides (length, hashtag count, structure). The legacy `global_rules` block remains the source of truth for the linkedin-standalone format (backward compat). The `per_fixture` list now lists 10 fixtures (F1..F10) and each can carry per-format overrides. Format keys: 'linkedin_standalone' (= legacy 'linkedin-copy'), 'linkedin_share' (short post linking to blog_url), 'blog' (long-form Markdown).",
  "global_rules": {
    "R1_total_len_min": 400,
    "R1_total_len_max": 3000,
    "R2_hook_max_chars": 120,
    "R3_body_min": 600,
    "R3_body_max": 1800,
    "R4_requires_url": true,
    "R5_hashtag_min": 3,
    "R5_hashtag_max": 5,
    "R6_hashtag_allowlist": [
      "#BIM", "#AECO", "#Construccion", "#Arquitectura", "#Ingenieria", "#OpenBIM",
      "#IFC", "#Revit", "#ArchiCAD", "#Navisworks", "#Dynamo", "#Grasshopper", "#OpenCDE",
      "#IA", "#InteligenciaArtificial", "#LowCode", "#Automation", "#Automatizacion", "#GenAI", "#LLM", "#MachineLearning", "#DigitalTwin",
      "#UmbralBIM"
    ],
    "R7_emoji_blocklist": ["✨","🚀","💡","🔥","🎯","🙌","👇","🤖","⚡","🌟","💪","🎉","❤️","💯","✅","🟢","🔴","🟡","📊","📈","⭐","💼","📌","👀","🙏","😀","😃","😄","😎","🎓","🏗️","🏢"],
    "R8_token_blocklist": ["transformación digital","transformacion digital","synergia","synergy","powered by","Don't miss","[TODO]","__","revolución digital","revolucion digital","unlock potential","game changer","next level","el futuro del trabajo"],
    "R9_register_blocklist": ["usted","vosotros","vuestro","vuestra"],
    "R10_min_paragraphs": 3,
    "R11_cta_blocklist": ["agendá tu demo","agenda tu demo","agendá una demo","reservá tu","reserva tu","contactanos","contáctanos","book a call","book your","link en bio","escribime al dm","escribeme al dm","mandame dm","escribeme un dm","mandame un dm"]
  },
  "formats": {
    "linkedin_standalone": {
      "_doc": "Existing single-format rules (was the only format pre-multiformat). Equivalent to applying global_rules unchanged.",
      "total_len_min": 400,
      "total_len_max": 3000,
      "hook_max_chars": 120,
      "body_min": 600,
      "body_max": 1800,
      "hashtag_min": 3,
      "hashtag_max": 5,
      "min_paragraphs": 3,
      "requires_source_url": true,
      "requires_blog_url": false,
      "allows_markdown_headings": false
    },
    "linkedin_share": {
      "_doc": "Short LinkedIn post that promotes the blog article. Body intentionally short (200-600 chars) — defer to blog for full argument.",
      "total_len_min": 400,
      "total_len_max": 1500,
      "hook_max_chars": 120,
      "body_min": 200,
      "body_max": 600,
      "hashtag_min": 3,
      "hashtag_max": 5,
      "min_paragraphs": 1,
      "requires_source_url": false,
      "requires_blog_url": true,
      "allows_markdown_headings": false
    },
    "blog": {
      "_doc": "Long-form blog article in Markdown. No hashtags. Headings allowed. Source URL required at end.",
      "total_len_min": 2000,
      "total_len_max": 6000,
      "hook_max_chars": 200,
      "body_min": 1800,
      "body_max": 5000,
      "hashtag_min": 0,
      "hashtag_max": 0,
      "min_paragraphs": 4,
      "requires_source_url": true,
      "requires_blog_url": false,
      "allows_markdown_headings": true,
      "requires_h1": true
    }
  },
  "per_fixture": [
    {"id": "F1-bim-only-clash-detection", "disciplines": ["BIM"]},
    {"id": "F2-bim-plus-ia-paper", "disciplines": ["BIM", "IA"]},
    {"id": "F3-bim-plus-automation-dynamo", "disciplines": ["BIM", "automation", "Dynamo"]},
    {"id": "F4-low-code-citizen-dev", "disciplines": ["low-code", "automation"]},
    {"id": "F5-mix-ia-bim-low-code-edge", "disciplines": ["BIM", "IA", "low-code"]},
    {"id": "F6-edge-bim-no-tech", "disciplines": ["BIM"]},
    {"id": "F7-openbim-ifc-export-pain", "disciplines": ["BIM", "OpenBIM", "IFC"]},
    {"id": "F8-bim-mep-coordination-tradeoff", "disciplines": ["BIM", "MEP"]},
    {"id": "F9-genai-revit-plugin-skeptic", "disciplines": ["BIM", "IA", "GenAI", "Revit"]},
    {"id": "F10-edge-isobim-nondigital-team", "disciplines": ["BIM", "ISO19650"]}
  ],
  "scoring": {
    "hard_rules": ["R1","R2","R4","R5","R7","R8","R9","R11"],
    "soft_rules": ["R3","R6","R10","R12"],
    "formula": "score = 0.7 * (hard_pass / hard_total) + 0.3 * (soft_pass / soft_total)",
    "threshold": 0.80,
    "hard_rule_pass_required": 1.0,
    "_doc_format_overrides": "Per-format scoring uses formats.<fmt> for length/hashtag bounds; rules R7/R8/R9/R11 (emojis, slop, register, CTA) are universal across formats and use global_rules. Blog format swaps R5 (hashtag count) for R5_blog_no_hashtags = (hashtag_count == 0) and gains R13_blog_h1 (first non-empty line starts with '# '). linkedin_share swaps R4 (source URL) for R4_share_blog_url = (blog_url substring present)."
  }
}
